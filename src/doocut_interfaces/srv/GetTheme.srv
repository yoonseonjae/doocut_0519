# GetTheme.srv
# 음성 발화로부터 테마를 추출해 테마명 + 소품 리스트를 반환한다.
# voice_processing/get_keyword.py 가 서버, photo_booth_manager 가 클라이언트.

# --- Request ---
# trigger=true 로 호출하면 STT->GPT 파이프라인을 1회 실행한다.
bool trigger
---
# --- Response ---
bool   success          # 테마 추출 성공 여부
string theme             # 추출된 테마 키워드 (예: "beach", "princess")
string[] props           # 해당 테마 소품 리스트 (예: ["straw_hat","sunglasses","shovel"])
string raw_text          # 원본 인식 문장 (디버그용)
string message           # 실패 사유 등 부가 메시지
