# PhotoSession.action
# 사람 위치를 기준점으로 TCP(카메라)가 원호/4웨이포인트 궤적을 돌며
# 각 포인트에서 고화질 캡처를 수행하는 동적 촬영 액션.
# robot_control/photo_motion.py 가 액션 서버, photo_booth_manager 가 클라이언트.
# 코딩 규칙 §11(멀티스레드 액션 서버) / §18(amovel+check_motion) 패턴 준수.

# --- Goal ---
bool start_task                 # true 로 촬영 세션 시작
string theme                    # 테마 (프레임/멘트 매칭용, 선택)
# 피사체 중심 [x, y, z, rx, ry, rz] (mm/deg). 길이 0 이면 서버가 기본값 사용
float64[] subject_center
int32 num_shots                 # 촬영 컷 수 (0 이면 기본 4컷)
---
# --- Result ---
bool   complete_task            # 전체 촬영 성공 여부
int32  captured_count           # 실제 캡처된 컷 수
string[] image_paths            # 저장된 원본 이미지 경로 리스트
float64  total_duration         # 총 소요 시간(초)
float64[] final_pose            # 종료 시 로봇 포즈 [x,y,z,rx,ry,rz]
string   message                # 부가 메시지
---
# --- Feedback ---
string  feedback_string         # 현재 작업 설명 (예: "2번 포인트 이동 중")
float64 progress_percentage     # 0.0 ~ 100.0
int32   current_shot            # 현재 촬영 중인 컷 번호 (1-base)
